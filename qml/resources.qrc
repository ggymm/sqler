        <file alias="qml/Dialogs/ConnectionTypes/RedisForm.qml">Dialogs/ConnectionTypes/RedisForm.qml</file>
        <file alias="qml/Views/TablesPane.qml">Views/TablesPane.qml</file>

        <file alias="assets/icons/add.svg">../assets/icons/add.svg</file>
        <file alias="assets/icons/remove.svg">../assets/icons/remove.svg</file>
        <file alias="assets/icons/new-conn.svg">../assets/icons/new-conn.svg</file>
        <file alias="assets/icons/new-query.svg">../assets/icons/new-query.svg</file>
        <file alias="assets/icons/table.svg">../assets/icons/table.svg</file>
        <file alias="assets/icons/query.svg">../assets/icons/query.svg</file>
        <file alias="assets/icons/function.svg">../assets/icons/function.svg</file>
