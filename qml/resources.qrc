        <file alias="assets/icons/db/mysql.svg">../assets/icons/db/mysql.svg</file>
        <file alias="assets/icons/db/postgresql.svg">../assets/icons/db/postgresql.svg</file>
        <file alias="assets/icons/db/sqlserver.svg">../assets/icons/db/sqlserver.svg</file>
        <file alias="assets/icons/db/sqlite.svg">../assets/icons/db/sqlite.svg</file>
        <file alias="assets/icons/db/mongodb.svg">../assets/icons/db/mongodb.svg</file>
        <file alias="assets/icons/db/oracle.svg">../assets/icons/db/oracle.svg</file>
        <file alias="assets/icons/db/redis.svg">../assets/icons/db/redis.svg</file>
    </qresource>
</RCC>
